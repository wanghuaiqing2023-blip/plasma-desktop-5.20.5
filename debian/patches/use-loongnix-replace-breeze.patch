       <label>Name of the current splash theme</label>
-      <default>org.kde.breeze.desktop</default>
+      <default>cn.loongson.loongnix.desktop</default>
     </entry>
   </group>
 </kcfg>
--- plasma-desktop-5.20.5.orig/kcms/mouse/backends/x11/x11_backend.cpp
+++ plasma-desktop-5.20.5/kcms/mouse/backends/x11/x11_backend.cpp
@@ -133,7 +133,7 @@ void X11Backend::kcmInit()
 
