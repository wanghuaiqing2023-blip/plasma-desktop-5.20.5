+QPoint FolderModel::localMenuPosition() const
+{
+    QScreen *screen = nullptr;
+    for (auto *s : qApp->screens()) {
+        if (s->geometry().contains(m_menuPosition)) {
+            screen = s;
+            break;
+        }
+    }
+    if (screen) {
+        return m_menuPosition - screen->geometry().topLeft();
+    }
+    return m_menuPosition;
+}
 
