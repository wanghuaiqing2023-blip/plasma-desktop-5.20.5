#: globalpaths.cpp:58
#, kde-format
msgid ""
"<h1>Paths</h1>\n"
"This module allows you to choose where in the filesystem the files on your "
"desktop should be stored.\n"
"Use the \"Whats This?\" (Shift+F1) to get help on specific options."
msgstr ""
"<h1>Cesty</h1>\n"
"Tento modul vám umožňuje vybrať si, kam budú ukladané súbory pracovnej "
"plochy.\n"
"Použite \"Čo je to?\" (Shift+F1) ak potrebujete pomoc s niektorou voľbou."

#. i18n: ectx: property (text), widget (QLabel, label)
#: globalpaths.ui:17
#, kde-format
msgid "Desktop path:"
msgstr "Cesta k ploche:"

#. i18n: ectx: property (whatsThis), widget (KUrlRequester, kcfg_desktopLocation)
#: globalpaths.ui:24
#, kde-format
msgid ""
"This folder contains all the files which you see on your desktop. You can "
"change the location of this folder if you want to, and the contents will "
"move automatically to the new location as well."
msgstr ""
"Tento priečinok obsahuje všetky súbory, ktoré vidíte na vašej ploche. Ak "
"budete chcieť, môžete zmeniť jeho umiestnenie. Jeho obsah bude potom "
"automaticky presunutý do nového umiestnenia."

#. i18n: ectx: property (text), widget (QLabel, label_2)
#: globalpaths.ui:34
#, kde-format
msgid "Autostart path:"
msgstr "Cesta k priečinku Autostart:"

#. i18n: ectx: property (whatsThis), widget (KUrlRequester, kcfg_autostartLocation)
#: globalpaths.ui:41
#, kde-format
msgid ""
"This folder contains applications or links to applications (shortcuts) that "
"you want to have started automatically whenever the session starts. You can "
"change the location of this folder if you want to, and the contents will "
"move automatically to the new location as well."
msgstr ""
"Tento priečinok obsahuje programy alebo odkazy na programy (skratky), ktoré "
"sa majú automaticky spúšťať pri štarte KDE. Ak budete chcieť, môžete zmeniť "
"jeho umiestnenie. Jeho obsah bude potom automaticky presunutý do nového "
"umiestnenia."

#. i18n: ectx: property (text), widget (QLabel, label_3)
#: globalpaths.ui:51
#, kde-format
msgid "Documents path:"
msgstr "Cesta k dokumentom:"

#. i18n: ectx: property (whatsThis), widget (KUrlRequester, kcfg_documentsLocation)
#: globalpaths.ui:58
#, kde-format
msgid ""
"This folder will be used by default to load or save documents from or to."
msgstr ""
"Tento priečinok bude použitý ako štandardný pre načítavanie a ukladanie "
"vašich dokumentov."

#. i18n: ectx: property (text), widget (QLabel, label_4)
#: globalpaths.ui:68
#, kde-format
msgid "Downloads path:"
msgstr "Cesta k stiahnutým súborom:"

#. i18n: ectx: property (whatsThis), widget (KUrlRequester, kcfg_downloadsLocation)
#: globalpaths.ui:75
#, kde-format
msgid "This folder will be used by default to save your downloaded items."
msgstr ""
"Tento priečinok bude použitý ako štandardný pre ukladanie stiahnutých vecí."

#. i18n: ectx: property (text), widget (QLabel, label_5)
#: globalpaths.ui:85
#, kde-format
msgid "Videos path:"
msgstr "Cesta k videám:"

#. i18n: ectx: property (whatsThis), widget (KUrlRequester, kcfg_videosLocation)
#: globalpaths.ui:92
#, kde-format
msgid "This folder will be used by default to load or save movies from or to."
msgstr ""
"Tento priečinok bude použitý ako štandardný pre načítavanie a ukladanie "
"filmov."

#. i18n: ectx: property (text), widget (QLabel, label_6)
#: globalpaths.ui:102
#, kde-format
msgid "Pictures path:"
msgstr "Cesta k obrázkom:"

#. i18n: ectx: property (whatsThis), widget (KUrlRequester, kcfg_picturesLocation)
#: globalpaths.ui:109
#, kde-format
msgid ""
"This folder will be used by default to load or save pictures from or to."
msgstr ""
"Tento priečinok bude použitý ako štandardný pre načítavanie a ukladanie "
"obrázkov."

#. i18n: ectx: property (text), widget (QLabel, label_7)
#: globalpaths.ui:119
#, kde-format
msgid "Music path:"
msgstr "Cesta k hudbe:"

#. i18n: ectx: property (whatsThis), widget (KUrlRequester, kcfg_musicLocation)
#: globalpaths.ui:126
#, kde-format
msgid "This folder will be used by default to load or save music from or to."
msgstr ""
"Tento priečinok bude použitý ako štandardný pre načítavanie a ukladanie "
"hudby."